    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "ingest": "node ingest.js",
    "verify": "node verify.js"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.4.2",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "pdf-parse": "^2.4.5"
  }
}
